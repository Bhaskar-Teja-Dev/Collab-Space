{
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "buildCommand": "npm run build --workspace=client",
  "outputDirectory": "client/dist",
  "installCommand": "npm install",
  "framework": null,
  "env": {
    "VITE_API_URL": "@collab-space-api-url",
    "VITE_WS_URL": "@collab-space-ws-url"
  }
}
