# CollabSpace Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ─── Database (Supabase Postgres) ────────────────────────────────────────────
# Go to: Supabase → Settings → Database → Connection string
# Use "Session pooler" tab for migrations, "Transaction pooler" for runtime.

# Runtime connection (Transaction pooler, port 6543):
DATABASE_URL=postgresql://postgres.YOURREF:YOURPASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# Schema migration connection (Session pooler, port 5432):
MIGRATE_DATABASE_URL=postgresql://postgres.YOURREF:YOURPASSWORD@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-very-long-random-secret-here
JWT_EXPIRES_IN=7d

# ─── Redis (Upstash) ─────────────────────────────────────────────────────────
# Go to: Upstash → your Redis DB → Connect tab → ioredis section
# Format: rediss://default:PASSWORD@HOSTNAME.upstash.io:6379
REDIS_URL=rediss://default:YOURTOKEN@central-kite-XXXXX.upstash.io:6379

# ─── Supabase (optional — for future Supabase Auth) ──────────────────────────
SUPABASE_URL=https://YOURREF.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Allowed CORS origin (your client URL)
# Local dev: http://localhost:5173
# Production: https://your-app.vercel.app
CLIENT_ORIGIN=http://localhost:5173

# ─── Client (Vite) ────────────────────────────────────────────────────────────
# These are injected at build time. Must start with VITE_
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001
VITE_SUPABASE_URL=https://YOURREF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION values (update CLIENT_ORIGIN + VITE_API_URL for deploy):
#
# CLIENT_ORIGIN=https://your-app.vercel.app
# VITE_API_URL=https://collab-space-server.onrender.com
# VITE_WS_URL=wss://collab-space-server.onrender.com
